{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",           // Измени с NodeNext на commonjs
    "moduleResolution": "node",      // Измени с NodeNext на node
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}