

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id                        String   @id @default(uuid())
  make                      String
  model                     String
  year                      Int
  totalPriceDisplay         String
  totalPriceRaw             Int
  basePriceDisplay          String?
  basePriceRaw              Int?
  mileageDisplay            String?
  mileageRaw                Int?
  transmission              String?
  engineSize                String?
  inspection                String?
  repairHistory             Boolean?
  warranty                  String?
  color                     String?
  colorCodes                String?
  mainImage                 String?
  additionalImages          Json?    // храним как JSON массив
  shopName                  String?
  shopLocation              String?
  detailUrl                 String?  @unique
  page                      String?
  parsedAt                  DateTime
  makeTranslated            String?
  colorTranslated           String?
  transmissionTranslated    String?
  inspectionTranslated      String?
  warrantyTranslated        String?
  repairHistoryTranslated   String?
  modelTranslated           String?
  shopNameTranslated        String?
  shopLocationTranslated    String?

  @@map("cars")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}