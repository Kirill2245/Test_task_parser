

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id        String   @id @default(cuid())
  make      String
  model     String
  year      Int
  mileage   Int?
  price     Int
  images    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}